#!/usr/bin/env python3
"""certinel-bootstrap-admin - create or promote the first admin by CAC DN.

On a fresh database there are no admins and the app only ever inserts users
with is_admin=0, so there is no in-app way to make the first one. Run this
once as root on the dashboard host:

    certinel-bootstrap-admin "CN=DOE.JANE.1234567890,OU=PKI,O=Example Org,C=US"

It inserts the DN if absent (or promotes it if present), is_admin=1,
is_active=1. Idempotent. Reads the DB path from the same env the app uses
(CSR_DB_PATH / the certinel.env), falling back to the default.
"""
import os
import sqlite3
import sys
import time


def _load_db_path():
    # honour the same env file the app reads, then CSR_DB_PATH, then default
    env_path = os.environ.get("CERTINEL_ENV",
                              "/etc/certinel/certinel.env")
    val = os.environ.get("CSR_DB_PATH")
    if not val:
        try:
            with open(env_path) as f:
                for line in f:
                    line = line.strip()
                    if line.startswith("CSR_DB_PATH="):
                        val = line.split("=", 1)[1].strip().strip('"').strip("'")
                        break
        except OSError:
            pass
    return val or "/var/lib/certinel/jobs.db"


def _cn_from_dn(dn):
    for part in dn.split(","):
        part = part.strip()
        if part.upper().startswith("CN="):
            return part[3:]
    return dn[:64]


def main():
    if len(sys.argv) != 2 or not sys.argv[1].strip():
        print('usage: certinel-bootstrap-admin "<full CAC DN>"', file=sys.stderr)
        print('example: certinel-bootstrap-admin "CN=DOE.JANE.A.1234567890,OU=...,C=US"',
              file=sys.stderr)
        return 2

    dn = sys.argv[1].strip()
    db_path = _load_db_path()
    if not os.path.exists(db_path):
        print(f"ERROR: database not found at {db_path}", file=sys.stderr)
        print("Start certinel-api once so the schema is created, then re-run.",
              file=sys.stderr)
        return 1

    cn = _cn_from_dn(dn)
    now = time.time()
    conn = sqlite3.connect(db_path)
    try:
        existing = conn.execute(
            "SELECT is_admin FROM users WHERE dn = ?", (dn,)
        ).fetchone()
        if existing is None:
            conn.execute(
                "INSERT INTO users (dn, cn, email, is_admin, is_active, "
                "created_at, last_seen_at) VALUES (?, ?, NULL, 1, 1, ?, ?)",
                (dn, cn, now, now),
            )
            action = "created as admin"
        else:
            conn.execute(
                "UPDATE users SET is_admin = 1, is_active = 1 WHERE dn = ?",
                (dn,),
            )
            action = "promoted to admin" if not existing[0] else "already admin"
        conn.commit()
    finally:
        conn.close()

    print(f"OK: {cn} {action}")
    print(f"  dn: {dn}")
    print(f"  db: {db_path}")
    print("Restart is not required; the change takes effect on next request.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
