[Unit]
Description=Certheim - send certificate expiry warnings
After=network-online.target

[Service]
Type=oneshot
User=certinel
Group=certinel
WorkingDirectory=/opt/certinel
EnvironmentFile=-/etc/certinel/certinel.env
ExecStart=/opt/certinel/venv/bin/python3 -c 'import app; s,e = app.run_expiry_warnings(); print(f"expiry warnings: sent={s} errors={e}")'
Environment=PYTHONUNBUFFERED=1
