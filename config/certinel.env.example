# ============================================================================
# certinel.env  -  per-deployment configuration
# ============================================================================
# Copy this file to /etc/certinel/certinel.env on the target host,
# fill in the values for THAT environment, then:
#     chown certinel:certinel /etc/certinel/certinel.env
#     chmod 0640          /etc/certinel/certinel.env
#     systemctl restart certinel-api
#
# Format: plain KEY=value, one per line. '#' starts a comment. No shell
# expansion. Any key left unset falls back to the built-in default shown.
#
# This file is read by the Python app (app.py) AND loaded into the systemd
# units (certinel-api.service, certinel-expiry-warn.service) via EnvironmentFile.
# ----------------------------------------------------------------------------

# ---- Filesystem paths ------------------------------------------------------

# Root-owned helper dispatcher (under /opt/certinel, off /root) the app calls via sudo to generate keys/CSRs.
CSR_HELPER_PATH=/opt/certinel/helper/certinel_helper.sh

# Database backend. Default is SQLite (zero-config, file-backed). Certheim also
# runs on PostgreSQL via the db.py abstraction (validated end-to-end by the
# smoke suite's db-matrix) - pick ONE of the two blocks below.
#
# --- SQLite (default) ---
# Holds all jobs, users, groups, templates, fleet certs, and the audit log.
# Back this up (certinel-backup) before changes.
CSR_DB_PATH=/var/lib/certinel/jobs.db
#
# --- PostgreSQL (uncomment to use; needs requirements-postgres.txt / psycopg) ---
# Set EITHER a full URL:
#CSR_DB_URL=postgresql://certinel:CHANGEME@db.example.com:5432/certinel?sslmode=require
# ...OR the discrete parts (CSR_DB_BACKEND=postgres selects PG without a URL):
#CSR_DB_BACKEND=postgres
#CSR_DB_HOST=db.example.com
#CSR_DB_PORT=5432
#CSR_DB_NAME=certinel
#CSR_DB_USER=certinel
#CSR_DB_PASSWORD=CHANGEME
#CSR_DB_SSLMODE=require

# Directory where signed certificates are written and read back.
# Certheim data root lives under /var/opt (FHS). Must match the helper's
# ISSUED_DIR in certinel_helper.d/00-common.sh.
CSR_ISSUED_DIR=/var/opt/certinel/issued

# ---- Behavior --------------------------------------------------------------

# Browser session lifetime, in seconds. 28800 = 8 hours.
CSR_SESSION_TTL=28800

# Maximum accepted upload sizes, in bytes.
CSR_MAX_CERTLIST_BYTES=65536
CSR_MAX_CSR_BYTES=32768
CSR_MAX_CERT_BYTES=65536

# First-admin bootstrap. When 1, the FIRST user to log in on a brand-new,
# empty database is made admin automatically; self-disables once any user
# exists. Leave 0 normally; set 1 only for initial stand-up. Security note:
# only enable where mTLS verifies real CACs, so the first user is genuinely
# you and not an unauthenticated ip= identity.
CSR_BOOTSTRAP_FIRST_ADMIN=0

# ============================================================================
# EMAIL / SMG NOTIFICATIONS
# ============================================================================
# IMPORTANT: email settings are NOT read from this file. They live in a
# separate INI file because the in-app admin panel (Admin > Email (SMG))
# reads and WRITES them there. Editing them here would have no effect and
# would be overwritten by the admin UI.
#
# On a NEW server, create /etc/certinel/email.conf with the block below,
# owner certinel:certinel mode 0640, then refine it from the admin panel.
# The values here are the per-environment ones you must set:
#
#   [smtp]
#   # SMG relay IP or hostname. The relay must whitelist THIS server's IP
#   # for unauthenticated relay. This is the value that changes per site.
#   host = REPLACE_WITH_SMG_IP_OR_HOST
#   # Plain SMTP port (no TLS, no auth on an IP-whitelisted relay).
#   port = 25
#   # Whole-transaction timeout in seconds.
#   timeout = 10
#
#   [from]
#   # From: address on outgoing mail; the relay must accept it from this IP.
#   address = noreply-csr@example.com
#
#   [recipients]
#   # Optional global Cc on every notification (comma-separated). Blank = none.
#   cc =
#
#   [content]
#   # Base URL used in email bodies; set to THIS server's dashboard URL.
#   dashboard_url = https://csr.example.com/csr/
#
# To disable email entirely: leave [smtp] host empty.
# ============================================================================
