# --- Backups created during in-place deployments ---
*.bak.*
*.bak
*~

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.egg-info/
.pytest_cache/

# --- Local config (real values stay out of repo; templates with .example go in) ---
config/email.conf
config/certinel.env
config/*.local.*

# --- Database snapshots and WAL files ---
*.db
*.db-wal
*.db-shm

# --- Editor cruft ---
.idea/
.vscode/
*.swp
*.swo
.*.swp

# --- OS cruft ---
RELEASE-NOTES*
.DS_Store
Thumbs.db
desktop.ini

# --- Credentials / secrets (paranoia) ---
*.key
*.pem
secrets/
.env
.env.local

# Per-release notes are transient: the CI release job generates one to populate
# the GitLab Release page, but it is NOT committed (CHANGELOG.md is the durable
# history). Keep them out of the tree.
RELEASE-NOTES-v*.md
